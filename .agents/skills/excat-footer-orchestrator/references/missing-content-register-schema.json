{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Missing Content Register",
  "type": "object",
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "location": { "type": "string", "description": "Where in the footer this content belongs" },
          "description": { "type": "string", "description": "What content is missing" },
          "resolved": { "type": "boolean" }
        },
        "required": ["location", "description", "resolved"]
      }
    }
  },
  "required": ["items"]
}
