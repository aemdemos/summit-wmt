{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mobile Footer Agent Output",
  "type": "object",
  "properties": {
    "breakpointPx": { "type": "integer" },
    "stackingOrder": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Section types in the order they stack on mobile (top to bottom)"
    },
    "hasAccordionSections": { "type": "boolean" },
    "accordionDetails": {
      "type": "object",
      "properties": {
        "expandMode": { "type": "string", "enum": ["single", "multi", "none"] },
        "hasChevronIcons": { "type": "boolean" },
        "chevronAnimates": { "type": "boolean" },
        "animationType": { "type": "string" },
        "animationDuration": { "type": "string" },
        "sectionsCollapsed": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Section labels that collapse into accordions on mobile"
        }
      }
    },
    "hasForm": { "type": "boolean" },
    "formLayoutChange": {
      "type": "string",
      "description": "How the form layout changes on mobile (e.g. horizontal-to-vertical, same, hidden)"
    },
    "hasLocaleSelector": { "type": "boolean" },
    "localeSelectorMobileBehavior": { "type": "string" },
    "hasSocialIcons": { "type": "boolean" },
    "socialIconsLayoutChange": { "type": "string" },
    "hasVideo": { "type": "boolean" },
    "videoMobileBehavior": {
      "type": "string",
      "description": "poster-only, autoplay, hidden, same"
    },
    "hasBackToTop": { "type": "boolean" },
    "backToTopBehavior": { "type": "string" },
    "columnStackingDetails": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "desktopColumn": { "type": "string" },
          "mobilePosition": { "type": "integer" },
          "collapsesToAccordion": { "type": "boolean" }
        }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "uncertainty": { "type": "boolean" },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "required": [
    "breakpointPx", "stackingOrder", "hasAccordionSections",
    "hasForm", "hasLocaleSelector", "hasSocialIcons", "hasVideo",
    "confidence", "uncertainty", "notes"
  ]
}
